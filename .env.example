# Copy this file to `.env.local` and fill in the real values from the
# Supabase dashboard (Project Settings → API).
#
# .env.local is git-ignored — NEVER commit real credentials.

# --- Supabase ---------------------------------------------------------------
# Project URL. Safe to expose in the client bundle.
NEXT_PUBLIC_SUPABASE_URL=

# Anonymous public key. Safe to expose in the client bundle.
# Access to data is still gated by Row Level Security (RLS) in Postgres.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. NEVER expose to the browser.
# Used only in server-side code (lib/db/admin.ts) for privileged operations.
SUPABASE_SERVICE_ROLE_KEY=

# --- Site -------------------------------------------------------------------
# Canonical base URL of the site. Used by sitemap.ts, robots.ts and metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Analytics -------------------------------------------------------------
# Google Tag Manager container ID. Override the hardcoded default
# `GTM-5J2XKDJZ` only when testing a different container (ex.: preview env
# com GTM próprio). Em produção pode deixar vazio — o componente usa o
# default automaticamente.
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 measurement ID (opcional — se GA4 for configurado
# fora do GTM). Formato: G-XXXXXXXXXX.
NEXT_PUBLIC_GA_ID=

# --- LMS -------------------------------------------------------------------
# URL completa do LMS (Área do Aluno). Padrão: https://portal.alunosdigitais.com.
# Override se o path de entrada mudar (ex.: /login, /entrar).
NEXT_PUBLIC_LMS_URL=
